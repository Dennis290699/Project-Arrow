# This .gitignore file is placed at the root of the Unity project directory.
# Derived from standard GitHub Unity gitignore template.

/[Ll]ibrary/
/[Tt]emp/
/[Oo]bj/
/[Bb]uild/
/[Bb]uilds/
/[Ll]ogs/
/[Uu]ser[Ss]ettings/

# MemoryCaptures can get large and should not be tracked
/[Mm]emoryCaptures/

# Recorded video/captures
/[Rr]ecordings/

# Asset server cache
/[Aa]sset[Oo]nly/

# Autogenerated project files
/*.csproj
/*.unityproj
/*.sln
/*.suo
/*.tmp
/*.user
/*.userprefs
/*.pidb
/*.booproj
/*.svd
/*.class
/*.targets

# Unity 3D Generated File
/sysinfo.txt

# Crashlytics generated file
crashlytics-build.properties

# Packed Addressables
/[Aa]ssets/[Aa]ddressable[Aa]ssets[Dd]ata/*/[Ll]ayout.bin
/[Aa]ssets/[Aa]ddressable[Aa]ssets[Dd]ata/*/[Cc]ontent[Cc]atalog.json

# Finished Addressables builds
/[Aa]ssets/[Ss]treaming[Aa]ssets/[Aa]ddressables/*

# OS generated files
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
